{
  "name": "tabre-your-new-tab",
  "private": true,
  "version": "6.1.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "build:calendar": "node scripts/build-calendar.js",
    "watch:calendar": "nodemon --watch src/data/calendar-2083 --ext json --exec \"pnpm build:calendar\"",
    "predev": "pnpm build:calendar",
    "dev": "concurrently \"pnpm watch:calendar\" \"vite\"",
    "prebuild": "pnpm build:calendar",
    "build": "vite build",
    "prewatch": "pnpm build:calendar",
    "watch": "concurrently \"pnpm watch:calendar\" \"vite build --watch\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "@sbmdkl/nepali-date-converter": "^2.0.4",
    "bootstrap-icons": "^1.13.1"
  }
}
